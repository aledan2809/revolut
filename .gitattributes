# Auto-detect text files; force LF line endings (cross-platform safety)
* text=auto eol=lf

# Binary files (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.pdf binary

# Lock files keep their line endings
package-lock.json -text
yarn.lock -text
